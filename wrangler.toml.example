name = "misub"
type = "javascript"
account_id = ""
zone_id = ""
main = "src/index.js"
compatibility_date = "2024-04-01"

# 本地开发配置
[env.local]
name = "misub-local"
routes = [
  { pattern = "localhost:8787/*", zone_name = "" }
]

# 生产环境配置
[env.production]
name = "misub"
routes = [
  { pattern = "example.com/*", zone_name = "example.com" }
]

# Pages 配置（推荐用于部署）
[env.pages]
name = "misub-pages"

# Cron Triggers 配置
# 如果使用 Cloudflare Pages Functions 的 Cron Triggers，取消下面的注释
# [triggers]
# crons = [
#   "0 * * * *",      # 每小时同步
#   "0 8 * * *",      # 每天8点完整同步  
#   "*/30 * * * *"    # 每30分钟检查流量
# ]

# 开发服务器配置
[dev]
port = 8787
local_protocol = "http"

# KV 命名空间绑定（本地调试）
[[kv_namespaces]]
binding = "KV_STORAGE"
id = "local"
preview_id = "local"

# D1 数据库绑定（本地调试）
# [[d1_databases]]
# binding = "DB"
# database_name = "misub"
# database_id = ""

# 兼容性选项
compatibility_flags = [
  "nodejs_compat"
]

# 日志配置
[logger]
enabled = true
